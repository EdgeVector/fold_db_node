{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FoldDB E2E Scenario",
  "type": "object",
  "required": ["name", "description", "nodes"],
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["role", "display_name"],
        "properties": {
          "role": { "type": "string" },
          "display_name": { "type": "string" }
        }
      }
    },
    "fixtures": { "type": "object" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "roles", "actions"],
        "properties": {
          "id": { "type": "string" },
          "roles": { "type": "array", "items": { "type": "string" } },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["action"],
              "properties": {
                "action": {
                  "type": "string",
                  "enum": [
                    "opt_in_all",
                    "opt_in_photography",
                    "publish",
                    "ingest_photo",
                    "face_search",
                    "text_search",
                    "connect",
                    "poll_requests",
                    "accept_request",
                    "decline_request",
                    "share_record",
                    "poll_notifications",
                    "expect_pending",
                    "expect_notification",
                    "expect_contact",
                    "expect_mutual_contact"
                  ]
                }
              },
              "additionalProperties": true
            }
          }
        }
      }
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node", "field", "op", "value"],
        "properties": {
          "node": { "type": "string" },
          "field": {
            "type": "string",
            "enum": [
              "contact_count",
              "notification_count",
              "pending_requests",
              "schema_record_count",
              "my_pseudonym_count",
              "shared_by"
            ]
          },
          "op": {
            "type": "string",
            "enum": ["==", "!=", ">=", "<=", ">", "<", "contains"]
          },
          "value": {},
          "timeout": { "type": "integer" }
        }
      }
    }
  }
}
