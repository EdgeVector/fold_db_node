{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FoldDB E2E Scenario",
  "description": "Schema for test-framework/scenarios/*.yaml. Kept in sync with the action dispatch in lib/step_executor.sh and the assertion fields in lib/assertions.sh. If you add a new action or assertion field, update both the code AND this schema in the same commit.",
  "type": "object",
  "required": ["name", "description", "nodes", "steps"],
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["role"],
        "properties": {
          "role": { "type": "string" },
          "display_name": { "type": "string" }
        }
      }
    },
    "fixtures": { "type": "object" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "roles", "actions"],
        "properties": {
          "id": { "type": "string" },
          "roles": { "type": "array", "items": { "type": "string" } },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["action"],
              "properties": {
                "action": {
                  "type": "string",
                  "enum": [
                    "ingest_photo",
                    "opt_in_photography",
                    "opt_in_all",
                    "publish",
                    "face_search",
                    "expect_results_min",
                    "connect",
                    "connect_all_results",
                    "export_pseudonyms",
                    "poll_requests",
                    "expect_pending_min",
                    "expect_notification_min",
                    "accept_request",
                    "share_record",
                    "sleep",
                    "org_create",
                    "org_join",
                    "sync_trigger",
                    "schema_register",
                    "mutation_write",
                    "set_org_hash",
                    "query_schema"
                  ]
                }
              },
              "additionalProperties": true
            }
          }
        }
      }
    },
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node", "field", "op", "value"],
        "properties": {
          "node": { "type": "string" },
          "field": {
            "type": "string",
            "enum": [
              "contact_count",
              "notification_count",
              "pending_requests",
              "schema_record_count",
              "shared_record_count",
              "my_pseudonym_count",
              "org_member_count",
              "last_query_result_count"
            ]
          },
          "op": {
            "type": "string",
            "enum": ["==", "!=", ">=", "<=", ">", "<"]
          },
          "value": {},
          "schema": { "type": "string" },
          "author_role": { "type": "string" },
          "org_role": { "type": "string" },
          "query_name": { "type": "string" }
        }
      }
    }
  }
}
