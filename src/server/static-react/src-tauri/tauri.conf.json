{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FoldDB",
  "version": "0.2.3",
  "identifier": "com.folddb.app",
  "build": {
    "devUrl": "http://localhost:9001",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "localhost",
      "signingIdentity": null,
      "entitlements": null
    },
    "category": "Developer Tool",
    "shortDescription": "Personal Database for Data Sovereignty",
    "longDescription": "FoldDB is a powerful personal database with AI-powered ingestion, schema management, and natural language queries. Built with Rust for performance and security."
  }
}
